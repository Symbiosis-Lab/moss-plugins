{
  "name": "github",
  "version": "1.5.1",
  "description": "Deploy to GitHub Pages via GitHub Actions",
  "author": "moss team",
  "entry": "main.bundle.js",
  "capabilities": ["deploy"],
  "requires": ["execute_binary"],
  "domain": "github.com",
  "global_name": "GithubPlugin",
  "icon": "icon.svg",
  "config": {
    "auto_commit": true,
    "video_max_size_mb": 75
  },
  "config_schema": {
    "auto_commit": "boolean",
    "video_max_size_mb": "number"
  }
}
