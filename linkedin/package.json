{
  "name": "linkedin",
  "version": "0.1.0",
  "description": "Syndicate articles between local system and LinkedIn",
  "main": "dist/main.bundle.js",
  "scripts": {
    "build": "npm run clean && npm run bundle && npm run copy-assets",
    "dev": "npm run clean && npm run copy-assets && concurrently \"esbuild src/main.ts --bundle --format=iife --global-name=LinkedInPlugin --outfile=dist/main.bundle.js --watch\" \"npm run watch-assets\"",
    "bundle": "esbuild src/main.ts --bundle --format=iife --global-name=LinkedInPlugin --outfile=dist/main.bundle.js",
    "clean": "rm -rf dist && mkdir -p dist",
    "copy-assets": "cp assets/* dist/",
    "watch-assets": "chokidar 'assets/**/*' -c 'npm run copy-assets'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --project unit --coverage",
    "test:unit": "vitest run --project unit"
  },
  "keywords": ["moss", "plugin", "linkedin", "syndication"],
  "author": "Symbiosis Lab",
  "license": "MIT",
  "devDependencies": {
    "@symbiosis-lab/moss-api": "workspace:*",
    "@tauri-apps/api": "^2.9.1",
    "@vitest/coverage-v8": "^3.2.4",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^8.2.0",
    "esbuild": "^0.27.0",
    "happy-dom": "^20.0.11",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  }
}
