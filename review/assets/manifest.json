{
  "name": "review",
  "version": "0.2.0",
  "description": "Enrich review posts with metadata from NeoDB, Douban, TMDB, and Goodreads",
  "display_name": "Reviews",
  "author": "moss team",
  "entry": "main.bundle.js",
  "capabilities": [
    "process",
    "enhance"
  ],
  "slots": [
    "head-end",
    "after-title",
    "before-article-end"
  ],
  "global_name": "ReviewPlugin",
  "icon": "icon.svg",
  "config": {},
  "config_schema": {},
  "contributes": {
    "frontmatter": {
      "fields": {
        "review_of": {
          "type": "string",
          "widget": "text-input",
          "description": "URL of item being reviewed (NeoDB, Douban, TMDB, Goodreads)"
        },
        "rating": {
          "type": "integer",
          "widget": "number-input",
          "description": "Your rating (1-5 stars)"
        }
      }
    }
  }
}
