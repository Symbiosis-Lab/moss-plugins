{
  "name": "matters",
  "version": "1.4.3",
  "description": "Syndicate your articles to Matters.town (POSSE)",
  "author": "moss team",
  "entry": "main.bundle.js",
  "capabilities": [
    "process",
    "syndicate",
    "import",
    "login"
  ],
  "global_name": "MattersPlugin",
  "domain": "matters.town",
  "domains": ["matters.town", "matters.icu"],
  "icon": "icon.svg",
  "config": {
    "auto_publish": false,
    "add_canonical_link": true,
    "sync_on_build": true,
    "sync_drafts": true
  },
  "config_schema": {
    "auto_publish": "boolean",
    "add_canonical_link": "boolean",
    "sync_on_build": "boolean",
    "sync_drafts": "boolean"
  },
  "contributes": {
    "jobs": {
      "syndicate": {
        "verb": "Syndicated",
        "noun": "posts"
      }
    }
  }
}
