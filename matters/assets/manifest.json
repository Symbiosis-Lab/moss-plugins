{
  "name": "matters",
  "version": "1.4.6",
  "description": "Syndicate your articles to Matters.town (POSSE)",
  "author": "moss team",
  "entry": "main.bundle.js",
  "capabilities": [
    "process",
    "syndicate",
    "import",
    "login"
  ],
  "global_name": "MattersPlugin",
  "domain": "matters.town",
  "domains": ["matters.town", "matters.icu"],
  "icon": "icon.svg",
  "config": {
    "add_canonical_link": true,
    "sync_on_build": true
  },
  "config_schema": {
    "add_canonical_link": "boolean",
    "sync_on_build": "boolean"
  },
  "config_labels": {
    "sync_on_build": "Auto-Import Posts"
  },
  "config_descriptions": {
    "add_canonical_link": "Add a link back to your site when your posts are syndicated to Matters.",
    "sync_on_build": "Automatically check Matters.town for new posts and drafts each time your site rebuilds."
  },
  "contributes": {
    "jobs": {
      "syndicate": {
        "verb": "Syndicated",
        "noun": "posts"
      }
    }
  }
}
